# Environment Configuration for African LCA Assessment API
# Copy this file to .env and fill in your actual values

# ============================================
# AI Report Generation (Required for AI Reports)
# ============================================
# Get your API key from: https://console.anthropic.com/
# Sign up for a free account to get started
# Used by: AI report generation + matching subsystem's LLM query expansion
ANTHROPIC_API_KEY=sk-ant-api03-your_api_key_here

# Get your API key from: https://platform.openai.com/api-keys
# Used by: matching subsystem (OpenAI embeddings + optional LLM query expansion).
# If unset, matching falls back to the offline lexical embedder — no key needed.
OPENAI_API_KEY=sk-proj-your_api_key_here

# ============================================
# API Configuration (Optional)
# ============================================
# API_HOST=0.0.0.0
# API_PORT=8000

# ============================================
# Application database (users, farms, assessments)
# ============================================
# Separate from the LCA canonical store at data/canonical/lca_engineer.sqlite
# (that file is copied onto the server; see DEPLOYMENT.md — never commit it).
# Leave unset for local SQLite at data/app/greenmeansgo.sqlite.
# In production, use a fresh DB (or Postgres) — do not restore your laptop user DB.
# DATABASE_URL=postgresql://user:password@localhost/greenmeansgo

# ============================================
# CORS Configuration (Optional)
# ============================================
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Logging Configuration (Optional)
# ============================================
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# ============================================
# Notes
# ============================================
# 1. Never commit the actual .env file to version control
# 2. Keep your API keys secure
# 3. Rotate API keys periodically
# 4. Monitor API usage in Anthropic Console
